# ==================== PERFIL ====================
SPRING_PROFILES_ACTIVE=prod

# ==================== API ====================
SERVER_PORT=8080
API_PUBLIC_PORT=8080

# ==================== DATABASE ====================
POSTGRES_DB=ayni_trazabilidad
DB_USERNAME=ayni_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=jdbc:postgresql://postgres:5432/ayni_trazabilidad
DB_URL=jdbc:postgresql://postgres:5432/ayni_trazabilidad
# Pool tuning (opcional)
# DB_POOL_SIZE=20
# DB_POOL_MIN_IDLE=10
# DB_CONNECTION_TIMEOUT=30000
# DB_IDLE_TIMEOUT=600000
# DB_MAX_LIFETIME=1800000

# ==================== JWT ====================
JWT_SECRET=CHANGE_ME_256_BITS_MIN
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# ==================== SECURITY ====================
CORS_ORIGINS=https://tu-frontend.com
RATE_LIMIT_AUTH=3
RATE_LIMIT_API=60

# ==================== ADMIN ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
# Seguro dejarlo true: si admin existe, solo valida estado/rol y no cambia password
ADMIN_BOOTSTRAP_ENABLED=true
DATA_INITIALIZER_ENABLED=false

# ==================== APP ====================
LOG_LEVEL=WARN
SHOW_SQL=false
DDL_AUTO=validate
LOG_FILE=/app/logs/ayni-trazabilidad.log
MAX_FILE_SIZE=2MB
MAX_REQUEST_SIZE=2MB
BUCKET_BASE_URL=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PRESIGN_EXPIRATION_SECONDS=300
